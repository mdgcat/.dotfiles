# vim:ft=sh

ssh_tar() {
    tar -pcz $1 | ssh $2 'tar -xz'
}

ssh_untar() {
    ssh $1 "tar -pcz $2" | tar -pxz
}

du_sorted () {
    du "$@" | sort -n | get_col 2 | xargs du -hs
}

# Create a new directory and enter it
function mkd() {
    mkdir -p "$@" && cd "$@"
}

# Determine size of a file or total size of a directory
function fs() {
    if du -b /dev/null > /dev/null 2>&1; then
        local arg=-sbh
    else
        local arg=-sh
    fi
    if [[ -n "$@" ]]; then
        du $arg -- "$@"
    else
        du $arg .[^.]* *
    fi
}

# Compare original and gzipped file size
function gz() {
    local origsize=$(wc -c < "$1")
    local gzipsize=$(gzip -c "$1" | wc -c)
    local ratio=$(echo "$gzipsize * 100/ $origsize" | bc -l)
    printf "orig: %d bytes\n" "$origsize"
    printf "gzip: %d bytes (%2.2f%%)\n" "$gzipsize" "$ratio"
}

# Test if HTTP compression (RFC 2616 + SDCH) is enabled for a given URL.
# Send a fake UA string for sites that sniff it instead of using the Accept-Encoding header. (Looking at you, ajax.googleapis.com!)
function httpcompression() {
    encoding="$(curl -LIs -H 'User-Agent: Mozilla/5 Gecko' -H 'Accept-Encoding: gzip,deflate,compress,sdch' "$1" | grep '^Content-Encoding:')" && echo "$1 is encoded using ${encoding#* }" || echo "$1 is not using any encoding"
}

# Syntax-highlight JSON strings or files
# Usage: `json '{"foo":42}'` or `echo '{"foo":42}' | json`
function json() {
    if [ -t 0 ]; then # argument
        python -mjson.tool <<< "$*" | pygmentize -l javascript
    else # pipe
        python -mjson.tool | pygmentize -l javascript
    fi
}

# Escape UTF-8 characters into their 3-byte format
function escape() {
    printf "\\\x%s" $(printf "$@" | xxd -p -c1 -u)
    echo # newline
}

# Decode \x{ABCD}-style Unicode escape sequences
function unidecode() {
    perl -e "binmode(STDOUT, ':utf8'); print \"$@\""
    echo # newline
}

# Get a character’s Unicode code point
function codepoint() {
    perl -e "use utf8; print sprintf('U+%04X', ord(\"$@\"))"
    echo # newline
}

# Manually remove a downloaded app or file from the quarantine
function unquarantine() {
    for attribute in com.apple.metadata:kMDItemDownloadedDate com.apple.metadata:kMDItemWhereFroms com.apple.quarantine; do
	xattr -r -d "$attribute" "$@"
    done
}

function removeMacData() {
    # ${1:-.} is a bash parameter expansion with a default value:
    #   $1 — the first argument passed to the function
    #   :- — "use this default if the value is unset or empty"
    #   .  — the default value, which means "current directory"
    # So ${1:-.} means: use $1 if it was provided, otherwise use .
    #
    # Examples:
    # - removeMacData /tmp/foo → runs find /tmp/foo ...
    # - removeMacData → runs find . ...
    #
    # Prevent Creation on External/Network Drives on MacOS
    # For USB and external drives:
    #     defaults write com.apple.desktopservices DSDontWriteUSBStores -bool TRUE
    # For network servers and shared drives:
    #     defaults write com.apple.desktopservices DSDontWriteNetworkStores true

    find "${1:-.}" -type f \( -name '.DS_Store' -o -name '._*' \) -print -delete
}

function renfilename() {
    # $1 and $2 are the first and second arguments passed to the function.
    # 'local' means the variable only exists inside this function — it won't
    # leak out and overwrite anything in your shell session.
    local flag="$1"
    local input="$2"

    # [[ ... ]] is bash's test block. -z "$input" means "is this string empty?".
    # The whole condition says: if the flag is neither -t nor -f, OR if the input
    # is empty, bail out. 'return 1' exits the function with an error code
    # (non-zero = failure in Unix convention).
    if [[ "$flag" != "-t" && "$flag" != "-f" ]] || [[ -z "$input" ]]; then
        echo "Usage: renfilename [-t string | -f filename]"
        return 1
    fi

    # Characters to strip entirely — add more between the quotes as needed
    local strip_chars='-?:'

    # A one-liner if/else. && runs the right side if the left is true; || runs
    # its right side if the left was false. 'basename' strips the directory path
    # e.g. basename "/tmp/my file.txt" → "my file.txt". $( ) runs a command and
    # captures its output as a string.
    local text
    [[ "$flag" == "-f" ]] && text="$(basename "$input")" || text="$input"

    # This is a pipeline — the output of each command feeds into the next via |.
    # <<< "$text" is a here-string: it feeds the variable's value directly into
    # awk as if it were a file.
    #
    # awk is a text-processing language:
    #   $0                    = the entire input line
    #   split($0, words, " ") = split the line on spaces into array 'words',
    #                           returns the count as n
    #   words[1]              = first word, left as-is
    #   The for loop starts at word 2:
    #     tolower()               lowercases the whole word
    #     toupper(substr(w,1,1))  uppercases just the first character
    #                             substr(w,1,1) = character at position 1, length 1
    #     substr(w,2)             the rest of the word from position 2 onward
    #   Words get joined with "." between them
    #
    # tr "'" '_'        — tr is a character translator; replaces every ' with _
    # tr -d -- "$strip_chars" — -d means delete (not translate). The -- tells tr
    #                           that what follows is not a flag, so a leading -
    #                           in strip_chars is treated as a literal character.
    local result
    result=$(awk '{
        n = split($0, words, " ")
        out = words[1]
        for (i = 2; i <= n; i++) {
            w = tolower(words[i])
            w = toupper(substr(w, 1, 1)) substr(w, 2)
            out = out "." w
        }
        print out
    }' <<< "$text" | tr "'" '_' | tr -d -- "$strip_chars")

    if [[ "$flag" == "-t" ]]; then
        # -n on echo suppresses the trailing newline (you don't want a newline
        # copied to your clipboard).
        echo "$result"
        echo -n "$result" | xclip -selection clipboard
    else
        # dirname gives the directory portion of the path, and mv renames the
        # file in place. -- protects against filenames that start with -.
        mv -- "$input" "$(dirname "$input")/$result"
    fi
}
